{
  "version": 2,
  "name": "void-mod-training",
  "builds": [
    {
      "src": "frontend/public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/frontend/public/$1" },
    { "handle": "filesystem" },
    { "src": "/", "dest": "/frontend/public/index.html" }
  ]
}
